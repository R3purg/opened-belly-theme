{% stylesheet %}
  .testimonials-ds {
    background: var(--green-pale);
    padding: 88px 40px;
  }

  .testimonials-ds__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .testimonials-ds__header {
    text-align: center;
    margin-bottom: 52px;
  }

  .testimonials-ds__kicker {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--green-mid);
    margin-bottom: 10px;
  }

  .testimonials-ds__heading {
    font-family: var(--font-head);
    font-size: clamp(24px, 3vw, 38px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--fg);
  }

  .testimonials-ds__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .testimonial-card {
    background: var(--bg);
    border-radius: var(--radius);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    border: 1px solid var(--border);
    transition: box-shadow 0.2s;
  }

  .testimonial-card:hover {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .testimonial-card__stars {
    display: flex;
    gap: 3px;
    color: #f59e0b;
    font-size: 16px;
  }

  .testimonial-card__quote {
    font-size: 15px;
    line-height: 1.65;
    color: var(--fg);
    flex: 1;
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 4px;
    border-top: 1px solid var(--border);
  }

  .testimonial-card__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--green-pale);
    border: 2px solid var(--green-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 15px;
    color: var(--green-deep);
    flex-shrink: 0;
    overflow: hidden;
  }

  .testimonial-card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-card__name {
    font-size: 14px;
    font-weight: 700;
    color: var(--fg);
    line-height: 1.2;
  }

  .testimonial-card__meta {
    font-size: 12px;
    color: var(--fg-muted);
  }

  @media (max-width: 1024px) {
    .testimonials-ds__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .testimonials-ds {
      padding: 52px 16px;
    }

    .testimonials-ds__grid {
      grid-template-columns: 1fr;
    }

    .testimonials-ds__header {
      margin-bottom: 32px;
    }
  }
{% endstylesheet %}

<div class="testimonials-ds reveal">
  <div class="testimonials-ds__inner">
    <div class="testimonials-ds__header">
      {% if section.settings.kicker %}
        <div class="testimonials-ds__kicker">{{ section.settings.kicker }}</div>
      {% endif %}
      <h2 class="testimonials-ds__heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="testimonials-ds__grid">
      {% for block in section.blocks %}
        <div class="testimonial-card reveal" style="transition-delay: {{ forloop.index0 | times: 0.08 }}s;">
          <div class="testimonial-card__stars">
            {% for i in (1..block.settings.stars) -%}
              ★
            {%- endfor %}
            {% assign remaining = 5 | minus: block.settings.stars %}
            {% for i in (1..remaining) -%}
              ☆
            {%- endfor %}
          </div>
          <p class="testimonial-card__quote">"{{ block.settings.quote }}"</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">
              {% if block.settings.avatar %}
                {{
                  block.settings.avatar
                  | image_url: width: 80
                  | image_tag: alt: block.settings.name, loading: 'lazy'
                }}
              {% else %}
                {{ block.settings.name | slice: 0, 1 | upcase }}
              {% endif %}
            </div>
            <div>
              <div class="testimonial-card__name">{{ block.settings.name }}</div>
              {% if block.settings.meta %}
                <div class="testimonial-card__meta">{{ block.settings.meta }}</div>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker Text",
      "default": "Real Results"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Loved by thousands of customers."
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Stars"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This product has completely changed how I feel. I can't imagine my day without it!"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar Image (optional)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer Name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta (e.g. Verified buyer · 3 months ago)",
          "default": "Verified buyer · 2 months ago"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "quote": "I've tried so many similar products and this is the only one that actually works. The quality is outstanding and the support is incredible.",
            "name": "Anna K.",
            "meta": "Verified buyer · 3 months ago"
          }
        },
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "quote": "After just 2 weeks I noticed a huge difference in my posture. It's so comfortable I forget I'm wearing it. Highly recommended!",
            "name": "Michael R.",
            "meta": "Verified buyer · 1 month ago"
          }
        },
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "quote": "Perfect fit, breathable material, and fast shipping. Exactly what I needed and more. Will definitely be buying for my family too.",
            "name": "Laura S.",
            "meta": "Verified buyer · 6 weeks ago"
          }
        }
      ]
    }
  ]
}
{% endschema %}
