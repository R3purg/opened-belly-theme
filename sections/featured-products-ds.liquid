{% stylesheet %}
  .ds-products {
    padding: 88px 40px;
    background: var(--bg);
  }

  .ds-products__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ds-products__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 48px;
    gap: 24px;
  }

  .ds-products__kicker {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--green-mid);
    margin-bottom: 8px;
  }

  .ds-products__heading {
    font-family: var(--font-head);
    font-size: clamp(24px, 3vw, 38px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--fg);
  }

  .ds-products__see-all {
    font-size: 13px;
    font-weight: 600;
    color: var(--green-deep);
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 1.5px solid var(--green-deep);
    padding-bottom: 2px;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }

  .ds-products__see-all:hover {
    opacity: 0.7;
  }

  .ds-products__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .ds-product-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .ds-product-card__img {
    background: var(--cream);
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 3/4;
    margin-bottom: 16px;
    position: relative;
    transition: transform 0.3s var(--ease-out-cubic);
  }

  .ds-product-card:hover .ds-product-card__img {
    transform: translateY(-4px);
  }

  .ds-product-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .ds-product-card:hover .ds-product-card__img img {
    transform: scale(1.03);
  }

  .ds-product-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--green-deep);
    color: #fff;
    border-radius: 4px;
    padding: 3px 8px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .ds-product-card__name {
    font-family: var(--font-head);
    font-size: 16px;
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 4px;
    line-height: 1.3;
  }

  .ds-product-card__price {
    font-size: 14px;
    color: var(--fg-muted);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ds-product-card__price s {
    opacity: 0.55;
  }

  .ds-product-card__price-sale {
    color: var(--green-deep);
    font-weight: 600;
  }

  .ds-product-card__btn {
    display: block;
    background: transparent;
    border: 1.5px solid var(--green-deep);
    color: var(--green-deep);
    border-radius: 50px;
    padding: 10px 20px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
    width: 100%;
  }

  .ds-product-card__btn:hover {
    background: var(--green-deep);
    color: #fff;
  }

  @media (max-width: 1024px) {
    .ds-products__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .ds-products {
      padding: 52px 16px;
    }

    .ds-products__header {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: 32px;
    }

    .ds-products__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .ds-product-card__name {
      font-size: 14px;
    }
  }

  @media (max-width: 480px) {
    .ds-products__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

<div class="ds-products reveal">
  <div class="ds-products__inner">
    <div class="ds-products__header">
      <div>
        {% if section.settings.kicker %}
          <div class="ds-products__kicker">{{ section.settings.kicker }}</div>
        {% endif %}
        <h2 class="ds-products__heading">{{ section.settings.heading }}</h2>
      </div>
      {% if section.settings.see_all_link %}
        <a href="{{ section.settings.see_all_link }}" class="ds-products__see-all">
          {{ section.settings.see_all_label | default: 'View all →' }}
        </a>
      {% endif %}
    </div>

    <div class="ds-products__grid">
      {% for block in section.blocks %}
        {% assign product_item = block.settings.product %}
        {% if product_item != blank %}
          <a href="{{ product_item.url }}" class="ds-product-card">
            <div class="ds-product-card__img">
              {% if product_item.featured_image %}
                {{
                  product_item.featured_image
                  | image_url: width: 600
                  | image_tag: loading: 'lazy', alt: product_item.featured_image.alt
                }}
              {% endif %}
              {% if product_item.compare_at_price > product_item.price %}
                <span class="ds-product-card__badge">Sale</span>
              {% elsif block.settings.badge_text %}
                <span class="ds-product-card__badge">{{ block.settings.badge_text }}</span>
              {% endif %}
            </div>
            <div class="ds-product-card__name">{{ product_item.title }}</div>
            <div class="ds-product-card__price">
              {% if product_item.compare_at_price > product_item.price %}
                <span class="ds-product-card__price-sale">{{ product_item.price | money }}</span>
                <s>{{ product_item.compare_at_price | money }}</s>
              {% else %}
                <span>{{ product_item.price | money }}</span>
              {% endif %}
            </div>
            <span class="ds-product-card__btn">
              {{ block.settings.btn_label | default: 'Shop Now' }}
            </span>
          </a>
        {% else %}
          <div class="ds-product-card">
            <div
              class="ds-product-card__img"
              style="background: var(--cream-dark); display:flex; align-items:center; justify-content:center; color:var(--fg-muted); font-size:12px;"
            >
              Select product
            </div>
            <div class="ds-product-card__name">Product Name</div>
            <div class="ds-product-card__price">€0.00</div>
            <span class="ds-product-card__btn">Shop Now</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker Text",
      "default": "Our Products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed for your wellbeing."
    },
    {
      "type": "url",
      "id": "see_all_link",
      "label": "See All Link"
    },
    {
      "type": "text",
      "id": "see_all_label",
      "label": "See All Label",
      "default": "View all →"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge Text (optional)",
          "default": "New"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "Shop Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "blocks": [{ "type": "product" }, { "type": "product" }, { "type": "product" }, { "type": "product" }]
    }
  ]
}
{% endschema %}
