{% stylesheet %}
  .collection-split {
    background: var(--bg);
    padding: 88px 40px;
  }

  .collection-split__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .collection-split__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .collection-split__kicker {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--green-mid);
    margin-bottom: 10px;
  }

  .collection-split__heading {
    font-family: var(--font-head);
    font-size: clamp(24px, 3vw, 38px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--fg);
  }

  .collection-split__grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 3), 1fr);
    gap: 20px;
  }

  .collection-tile {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 3/4;
    display: block;
    text-decoration: none;
  }

  .collection-tile__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .collection-tile:hover .collection-tile__img {
    transform: scale(1.04);
  }

  .collection-tile__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(6, 20, 6, 0.72) 100%);
  }

  .collection-tile__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 28px 24px;
  }

  .collection-tile__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--green-sage);
    margin-bottom: 6px;
  }

  .collection-tile__name {
    font-family: var(--font-head);
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 14px;
  }

  .collection-tile__btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #fff;
    border-radius: 50px;
    padding: 9px 18px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    transition: background 0.2s;
  }

  .collection-tile:hover .collection-tile__btn {
    background: rgba(255, 255, 255, 0.25);
  }

  .collection-tile--wide {
    aspect-ratio: unset;
    grid-column: span 2;
  }

  .collection-tile--wide .collection-tile__name {
    font-size: 28px;
  }

  @media (max-width: 768px) {
    .collection-split {
      padding: 52px 16px;
    }

    .collection-split__grid {
      --cols: 1 !important;
    }

    .collection-tile--wide {
      grid-column: span 1;
      aspect-ratio: 3/4;
    }

    .collection-split__header {
      margin-bottom: 28px;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .collection-split__grid {
      --cols: 2 !important;
    }

    .collection-tile--wide {
      grid-column: span 2;
    }
  }
{% endstylesheet %}

<div class="collection-split reveal">
  <div class="collection-split__inner">
    {% if section.settings.kicker or section.settings.heading %}
      <div class="collection-split__header">
        {% if section.settings.kicker %}
          <div class="collection-split__kicker">{{ section.settings.kicker }}</div>
        {% endif %}
        {% if section.settings.heading %}
          <h2 class="collection-split__heading">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
    {% endif %}

    <div class="collection-split__grid" style="--cols: {{ section.settings.columns }};">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.link | default: '/collections/all' }}"
          class="collection-tile{% if block.settings.wide %} collection-tile--wide{% endif %}"
        >
          {% if block.settings.image %}
            {{
              block.settings.image
              | image_url: width: 900
              | image_tag: class: 'collection-tile__img', loading: 'lazy', alt: block.settings.image.alt
            }}
          {% else %}
            <div class="collection-tile__img" style="background: var(--cream-dark);"></div>
          {% endif %}
          <div class="collection-tile__overlay"></div>
          <div class="collection-tile__content">
            {% if block.settings.label %}
              <div class="collection-tile__label">{{ block.settings.label }}</div>
            {% endif %}
            <div class="collection-tile__name">{{ block.settings.name }}</div>
            <span class="collection-tile__btn">
              {{ block.settings.btn_text | default: 'Shop Now' }}
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Split",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker Text",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find what works for you."
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Collection Tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (above title)",
          "default": "Featured"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Title",
          "default": "Support Belts"
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "wide",
          "label": "Wide tile (spans 2 columns)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Split",
      "blocks": [
        {
          "type": "tile",
          "settings": {
            "label": "Posture Support",
            "name": "Back & Lumbar",
            "btn_text": "Shop Now"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "Abdominal",
            "name": "Waist Trainers",
            "btn_text": "Shop Now"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "Daily Comfort",
            "name": "All Products",
            "btn_text": "View All"
          }
        }
      ]
    }
  ]
}
{% endschema %}
