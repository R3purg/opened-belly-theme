{% stylesheet %}
  .home-hero {
    background: var(--cream);
    padding-top: var(--header-group-height, 80px);
    overflow: hidden;
  }

  .home-hero__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 40px 0;
    display: grid;
    grid-template-columns: 5fr 4fr;
    gap: 64px;
    align-items: center;
  }

  .home-hero__kicker {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .home-hero__kicker-line {
    height: 2px;
    width: 32px;
    background: var(--brown);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .home-hero__kicker-text {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--brown);
  }

  .home-hero__heading {
    font-family: var(--font-head);
    font-size: clamp(38px, 5vw, 68px);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--fg);
    margin-bottom: 20px;
  }

  .home-hero__heading em {
    font-style: normal;
    color: var(--green-deep);
  }

  .home-hero__desc {
    font-size: 17px;
    line-height: 1.7;
    color: var(--fg-muted);
    margin-bottom: 36px;
    max-width: 480px;
  }

  .home-hero__btns {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 44px;
  }

  .home-hero__btns .btn-primary {
    padding: 17px 48px;
    font-size: 15px;
  }

  .home-hero__btns .btn-outline {
    padding: 16px 32px;
    font-size: 15px;
  }

  .home-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }

  .home-hero__trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--fg-muted);
  }

  .home-hero__trust-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green-sage);
    flex-shrink: 0;
  }

  /* Image stack */
  .home-hero__img-wrap {
    position: relative;
    padding-bottom: 0;
  }

  .home-hero__img-main {
    width: 100%;
    aspect-ratio: 3/4;
    background: var(--cream-dark);
    border-radius: var(--radius) var(--radius) 0 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .home-hero__img-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-hero__badge {
    position: absolute;
    top: 24px;
    right: -16px;
    background: var(--green-deep);
    color: #fff;
    border-radius: 50%;
    width: 88px;
    height: 88px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    box-shadow: 0 4px 20px rgba(23, 79, 25, 0.35);
  }

  .home-hero__badge-num {
    font-family: var(--font-head);
    font-size: 20px;
    font-weight: 700;
    line-height: 1;
  }

  .home-hero__badge-text {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.85;
    line-height: 1.3;
    padding: 0 8px;
  }

  @media (max-width: 1024px) {
    .home-hero__inner {
      gap: 40px;
      padding-top: 60px;
    }
  }

  @media (max-width: 768px) {
    .home-hero__inner {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 40px 16px 0;
    }

    .home-hero__heading {
      font-size: clamp(30px, 8vw, 48px);
    }

    .home-hero__desc {
      font-size: 15px;
      margin-bottom: 24px;
    }

    .home-hero__btns {
      flex-direction: column;
      gap: 10px;
      margin-bottom: 28px;
    }

    .home-hero__btns .btn-primary,
    .home-hero__btns .btn-outline {
      width: 100%;
      text-align: center;
    }

    .home-hero__img-main {
      aspect-ratio: 4/3;
    }

    .home-hero__badge {
      right: 8px;
      top: 16px;
      width: 72px;
      height: 72px;
    }

    .home-hero__badge-num {
      font-size: 16px;
    }
  }
{% endstylesheet %}

<div class="home-hero">
  <div class="home-hero__inner">
    <div style="padding-bottom: 64px; animation: fadeUp 0.65s ease both;">
      {% if section.settings.kicker %}
        <div class="home-hero__kicker">
          <div class="home-hero__kicker-line"></div>
          <div class="home-hero__kicker-text">{{ section.settings.kicker }}</div>
        </div>
      {% endif %}

      <h1 class="home-hero__heading">{{ section.settings.heading }}</h1>

      {% if section.settings.description %}
        <p class="home-hero__desc">{{ section.settings.description }}</p>
      {% endif %}

      <div class="home-hero__btns">
        {% if section.settings.primary_btn_label %}
          <a href="{{ section.settings.primary_btn_link | default: '/collections/all' }}" class="btn-primary">
            {{ section.settings.primary_btn_label }}
          </a>
        {% endif %}
        {% if section.settings.secondary_btn_label %}
          <a href="{{ section.settings.secondary_btn_link | default: '/collections/all' }}" class="btn-outline">
            {{ section.settings.secondary_btn_label }}
          </a>
        {% endif %}
      </div>

      <div class="home-hero__trust">
        {% if section.settings.trust_1 %}
          <div class="home-hero__trust-item">
            <div class="home-hero__trust-dot"></div>
            {{ section.settings.trust_1 }}
          </div>
        {% endif %}
        {% if section.settings.trust_2 %}
          <div class="home-hero__trust-item">
            <div class="home-hero__trust-dot"></div>
            {{ section.settings.trust_2 }}
          </div>
        {% endif %}
        {% if section.settings.trust_3 %}
          <div class="home-hero__trust-item">
            <div class="home-hero__trust-dot"></div>
            {{ section.settings.trust_3 }}
          </div>
        {% endif %}
      </div>
    </div>

    <div style="animation: fadeUp 0.65s 0.12s ease both;">
      <div class="home-hero__img-wrap">
        <div class="home-hero__img-main">
          {% if section.settings.hero_image %}
            {{
              section.settings.hero_image
              | image_url: width: 800
              | image_tag: loading: 'eager', alt: section.settings.hero_image.alt
            }}
          {% else %}
            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--cream-dark);color:var(--fg-muted);font-size:14px;font-family:var(--font-body);">
              Add hero image
            </div>
          {% endif %}
        </div>
        {% if section.settings.badge_text %}
          <div class="home-hero__badge">
            <div class="home-hero__badge-num">{{ section.settings.badge_num }}</div>
            <div class="home-hero__badge-text">{{ section.settings.badge_text }}</div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Home Hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker Text",
      "default": "Natural Comfort Solutions"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Feel better. Move freely. Live fully."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Premium body support products designed to help you move with confidence. Scientifically crafted for lasting comfort and real results."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "primary_btn_label",
      "label": "Primary Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "primary_btn_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_btn_label",
      "label": "Secondary Button Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "secondary_btn_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust Signal 1",
      "default": "Free Shipping"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust Signal 2",
      "default": "30-Day Returns"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust Signal 3",
      "default": "Clinically Tested"
    },
    {
      "type": "text",
      "id": "badge_num",
      "label": "Badge Number",
      "default": "50%"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text (leave blank to hide)",
      "default": "off today"
    }
  ],
  "presets": [
    {
      "name": "Home Hero"
    }
  ]
}
{% endschema %}
