<style>
  .chs {
    background: #061406;
    padding: 0;
  }
  .chs__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .chs__cell {
    padding: 36px 28px;
    text-align: center;
    border-right: 1px solid rgba(255, 255, 255, 0.07);
  }
  .chs__cell:last-child {
    border-right: none;
  }
  .chs__icon {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: rgba(163, 217, 165, 0.15);
    color: #a3d9a5;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 14px;
  }
  .chs__title {
    font-family: var(--font-heading--family, var(--font-primary--family, sans-serif));
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 6px;
  }
  .chs__body {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.55;
  }
  @media (max-width: 1024px) {
    .chs__inner {
      grid-template-columns: repeat(2, 1fr);
    }
    .chs__cell {
      border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    }
    .chs__cell:nth-child(2) {
      border-right: none;
    }
    .chs__cell:nth-last-child(-n + 2) {
      border-bottom: none;
    }
  }
  @media (max-width: 768px) {
    .chs__inner {
      grid-template-columns: 1fr;
      padding: 0 16px;
    }
    .chs__cell {
      padding: 28px 16px;
      border-right: none;
    }
    .chs__cell:not(:last-child) {
      border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    }
  }
</style>

{%- liquid
  assign shipping_icon = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>'
  assign returns_icon = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9 9 0 0 0-9 9z"/><polyline points="12 7 12 12 15 15"/></svg>'
  assign secure_icon = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>'
  assign rating_icon = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>'
-%}

<section class="chs">
  <div class="chs__inner">
    {% for block in section.blocks %}
      <div class="chs__cell" {{ block.shopify_attributes }}>
        <div class="chs__icon" aria-hidden="true">
          {% case block.settings.icon %}
            {% when 'shipping' -%}
              {{- shipping_icon }}
            {% when 'returns' -%}
              {{- returns_icon }}
            {% when 'secure' -%}
              {{- secure_icon }}
            {% when 'rating' -%}
              {{- rating_icon }}
            {% else -%}
              {{- shipping_icon }}
          {% endcase %}
        </div>
        <div class="chs__title">{{ block.settings.title }}</div>
        {% if block.settings.body != blank %}
          <div class="chs__body">{{ block.settings.body }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Help Strip",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "cell",
      "name": "Cell",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping / Package" },
            { "value": "returns", "label": "Returns / Clock" },
            { "value": "secure", "label": "Secure / Lock" },
            { "value": "rating", "label": "Rating / Star" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free EU shipping"
        },
        {
          "type": "text",
          "id": "body",
          "label": "Body",
          "default": "On orders over €40 — delivered in 5–9 days"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "presets": [
    {
      "name": "Help Strip",
      "blocks": [
        {
          "type": "cell",
          "settings": {
            "icon": "shipping",
            "title": "Free EU shipping",
            "body": "On orders over €40 — delivered in 5–9 days"
          }
        },
        {
          "type": "cell",
          "settings": {
            "icon": "returns",
            "title": "30-day returns",
            "body": "Send anything back, no questions asked"
          }
        },
        {
          "type": "cell",
          "settings": {
            "icon": "secure",
            "title": "Secure checkout",
            "body": "Stripe-encrypted payments, every order"
          }
        },
        {
          "type": "cell",
          "settings": {
            "icon": "rating",
            "title": "4.8\u2605 from 12,400+",
            "body": "Real reviews on Trustpilot & Google"
          }
        }
      ]
    }
  ]
}
{% endschema %}
