<style>
  .cph {
    background: linear-gradient(135deg, #174f19 0%, #2a6b2d 60%, #3d8f40 100%);
    padding: 48px 40px 60px;
    color: #fff;
    overflow: hidden;
    position: relative;
  }
  .cph__inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .cph__crumbs {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 18px;
    letter-spacing: 0.04em;
    list-style: none;
    padding: 0;
  }
  .cph__crumbs a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }
  .cph__crumbs a:hover {
    color: #fff;
  }
  .cph__crumbs-sep {
    opacity: 0.4;
  }
  .cph__crumbs-here {
    color: #fff;
    font-weight: 600;
  }
  .cph__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 50px;
    padding: 5px 14px 5px 8px;
    margin-bottom: 18px;
  }
  .cph__eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #a3d9a5;
    animation: cph-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes cph-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }
  .cph__eyebrow-text {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
    white-space: nowrap;
  }
  .cph__title {
    font-family: var(--font-heading--family, var(--font-primary--family, sans-serif));
    font-size: clamp(34px, 4.5vw, 56px);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.025em;
    margin-bottom: 16px;
    max-width: 780px;
    color: #fff;
  }
  .cph__title-accent {
    display: block;
    color: #a3d9a5;
  }
  .cph__sub {
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.74);
    max-width: 560px;
    margin-bottom: 0;
  }
  .cph__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 32px;
    margin-top: 32px;
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }
  .cph__stat-num {
    font-family: var(--font-heading--family, var(--font-primary--family, sans-serif));
    font-size: 24px;
    font-weight: 700;
    color: #fff;
    line-height: 1;
  }
  .cph__stat-label {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 4px;
    letter-spacing: 0.04em;
  }
  @media (max-width: 768px) {
    .cph {
      padding: 36px 16px 44px;
    }
    .cph__stats {
      gap: 24px;
    }
  }
</style>

<section class="cph">
  <div class="cph__inner">
    <nav aria-label="Breadcrumb">
      <ol class="cph__crumbs">
        <li><a href="{{ routes.root_url }}">Home</a></li>
        <li class="cph__crumbs-sep" aria-hidden="true">/</li>
        <li class="cph__crumbs-here">{{ section.settings.page_title }}</li>
      </ol>
    </nav>

    <div class="cph__eyebrow" aria-hidden="true">
      <div class="cph__eyebrow-dot"></div>
      <span class="cph__eyebrow-text">{{ section.settings.eyebrow }}</span>
    </div>

    <h1 class="cph__title">
      {{ section.settings.heading_line1 }}
      {% if section.settings.heading_line2 != blank %}
        <span class="cph__title-accent">{{ section.settings.heading_line2 }}</span>
      {% endif %}
    </h1>

    {% if section.settings.subheading != blank %}
      <p class="cph__sub">{{ section.settings.subheading }}</p>
    {% endif %}

    {% assign has_stats = false %}
    {% if section.settings.stat_1_num != blank
      or section.settings.stat_2_num != blank
      or section.settings.stat_3_num != blank
      or section.settings.stat_4_num != blank
    %}
      {% assign has_stats = true %}
    {% endif %}

    {% if has_stats %}
      <div class="cph__stats">
        {% if section.settings.stat_1_num != blank %}
          <div>
            <div class="cph__stat-num">{{ section.settings.stat_1_num }}</div>
            <div class="cph__stat-label">{{ section.settings.stat_1_label }}</div>
          </div>
        {% endif %}
        {% if section.settings.stat_2_num != blank %}
          <div>
            <div class="cph__stat-num">{{ section.settings.stat_2_num }}</div>
            <div class="cph__stat-label">{{ section.settings.stat_2_label }}</div>
          </div>
        {% endif %}
        {% if section.settings.stat_3_num != blank %}
          <div>
            <div class="cph__stat-num">{{ section.settings.stat_3_num }}</div>
            <div class="cph__stat-label">{{ section.settings.stat_3_label }}</div>
          </div>
        {% endif %}
        {% if section.settings.stat_4_num != blank %}
          <div>
            <div class="cph__stat-num">{{ section.settings.stat_4_num }}</div>
            <div class="cph__stat-label">{{ section.settings.stat_4_label }}</div>
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Collections Hero",
  "settings": [
    {
      "type": "text",
      "id": "page_title",
      "label": "Breadcrumb Label",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Badge",
      "default": "All Collections"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading Line 1",
      "default": "Curated picks for"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading Line 2 (accent colour)",
      "default": "every corner of life."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From kitchen essentials to wellness staples and pet-care must-haves — every product hand-tested by our team."
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat_1_num",
      "label": "Stat 1 Number",
      "default": "8"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 Label",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "stat_2_num",
      "label": "Stat 2 Number",
      "default": "240+"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 Label",
      "default": "Products"
    },
    {
      "type": "text",
      "id": "stat_3_num",
      "label": "Stat 3 Number",
      "default": "12.4k"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 Label",
      "default": "Happy Customers"
    },
    {
      "type": "text",
      "id": "stat_4_num",
      "label": "Stat 4 Number",
      "default": "4.8\u2605"
    },
    {
      "type": "text",
      "id": "stat_4_label",
      "label": "Stat 4 Label",
      "default": "Avg. Rating"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "presets": [
    {
      "name": "Collections Hero"
    }
  ]
}
{% endschema %}
